---
---

<section id="quienes-somos" class="section-padding bg-white">
  <div class="container-empiria">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Imagen -->
      <div class="relative">
        <div class="absolute -inset-4 bg-[#C17A5F]/10 rounded-[40px] rotate-2"></div>
        <div class="relative bg-[#F5F0E8] rounded-[40px] overflow-hidden aspect-square flex items-center justify-center">
          <div class="text-center p-8">
            <div class="w-24 h-24 bg-[#7C9A6B]/20 rounded-full mx-auto mb-4 flex items-center justify-center">
              <svg class="w-12 h-12 text-[#7C9A6B]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            </div>
            <p class="text-[#718096] text-sm">[Foto profesional]</p>
          </div>
        </div>

        <!-- Badge flotante -->
        <div class="absolute -bottom-6 -right-6 bg-white rounded-2xl shadow-xl p-4 flex items-center gap-3">
          <div class="w-12 h-12 bg-[#7C9A6B]/15 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-[#7C9A6B]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div>
            <p class="text-sm font-bold text-[#2D3748]">Colegiada</p>
            <p class="text-xs text-[#718096]">Profesional certificada</p>
          </div>
        </div>
      </div>

      <!-- Contenido -->
      <div>
        <span class="text-[#C17A5F] text-sm font-semibold uppercase tracking-wider">Quiénes Somos</span>
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-[#2D3748] mt-3 mb-6">
          Dra. Natalia Pérez
        </h2>
        <p class="text-[#718096] text-lg leading-relaxed mb-6">
          Fonoaudióloga y Magíster en Dificultades del Aprendizaje con más de 15 años de experiencia en evaluación y terapia educativa.
        </p>

        <div class="space-y-4 mb-8">
          <div class="flex items-start gap-3">
            <div class="w-6 h-6 bg-[#7C9A6B]/15 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-3 h-3 text-[#7C9A6B]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            </div>
            <p class="text-[#2D3748]">Magíster en Dificultades del Aprendizaje</p>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-6 h-6 bg-[#7C9A6B]/15 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-3 h-3 text-[#7C9A6B]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            </div>
            <p class="text-[#2D3748]">Especialista en Lectoescritura y Lenguaje</p>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-6 h-6 bg-[#7C9A6B]/15 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-3 h-3 text-[#7C9A6B]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            </div>
            <p class="text-[#2D3748]">Fonoaudióloga Colegiada No. 12345</p>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-6 h-6 bg-[#7C9A6B]/15 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-3 h-3 text-[#7C9A6B]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            </div>
            <p class="text-[#2D3748]">Especialista Educativa Certificada</p>
          </div>
        </div>

        <div class="bg-[#F5F0E8] rounded-2xl p-6 border-l-4 border-[#7C9A6B]">
          <p class="text-[#2D3748] italic leading-relaxed">
            "Mi enfoque no es masivo ni frío. Mi misión es acompañar a mis pacientes con calidez humana para devolverle la tranquilidad escolar y familiar a tu hogar."
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
