---
import { Icon } from 'astro-icon/components';

const pasos = [
  { icon: "lucide:message-circle", title: "Contacto inicial", desc: "Escríbenos por WhatsApp o llena el formulario. Te respondemos en menos de 24 horas." },
  { icon: "lucide:clipboard-check", title: "Valoración gratuita", desc: "Primera sesión sin costo para conocer el caso, evaluar necesidades y proponer un plan." },
  { icon: "lucide:file-text", title: "Plan personalizado", desc: "Diseñamos la intervención a medida, con objetivos claros y tiempos definidos." },
  { icon: "lucide:repeat", title: "Acompañamiento continuo", desc: "Sesiones regulares, seguimiento del avance y ajustes según el progreso." }
];
---

<section id="metodologia" class="py-20 md:py-32 bg-surface">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
      
      <!-- Timeline Column -->
      <div class="fade-up">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Nuestra Metodología</h2>
        <p class="text-lg text-slate-600 mb-12">
          Un proceso claro, transparente y centrado en las necesidades de tu familia.
        </p>

        <div class="space-y-8 relative before:absolute before:inset-0 before:ml-6 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-primary before:via-accent before:to-transparent">
          
          {pasos.map((paso, index) => (
            <div class="relative flex items-start justify-between md:justify-normal md:odd:flex-row-reverse group is-active">
              
              <!-- Icon -->
              <div class="flex items-center justify-center w-12 h-12 rounded-full border-4 border-surface bg-white text-primary shadow shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 relative z-10">
                <Icon name={paso.icon} class="w-5 h-5" />
              </div>
              
              <!-- Content -->
              <div class="w-[calc(100%-4rem)] md:w-[calc(50%-3rem)] p-6 rounded-2xl bg-white shadow-sm border border-slate-100 group-hover:shadow-md transition-all">
                <div class="flex items-center justify-between mb-1">
                  <h3 class="font-bold text-secondary text-lg">{paso.title}</h3>
                </div>
                <p class="text-slate-600 text-sm leading-relaxed">{paso.desc}</p>
              </div>
              
            </div>
          ))}

        </div>

        <div class="mt-12 flex flex-col sm:flex-row gap-6 p-6 bg-white rounded-2xl shadow-sm border border-slate-100">
          <div class="flex items-center gap-3">
            <Icon name="lucide:map-pin" class="w-6 h-6 text-primary" />
            <div>
              <p class="font-bold text-secondary text-sm">Presencial</p>
              <p class="text-slate-500 text-xs">Consultorio en Bogotá</p>
            </div>
          </div>
          <div class="hidden sm:block w-px bg-slate-200"></div>
          <div class="flex items-center gap-3">
            <Icon name="lucide:video" class="w-6 h-6 text-accent" />
            <div>
              <p class="font-bold text-secondary text-sm">Online</p>
              <p class="text-slate-500 text-xs">Terapia virtual global</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact Form Column -->
      <div id="contacto" class="fade-up" style="transition-delay: 200ms;">
        <div class="bg-white p-8 md:p-10 rounded-3xl shadow-xl">
          <h3 class="text-2xl md:text-3xl font-bold text-secondary mb-2">¿Hablamos sobre el caso de tu hijo?</h3>
          <p class="text-slate-500 mb-8">Déjanos tus datos y te contactaremos a la brevedad para agendar tu valoración gratuita.</p>
          
          <form class="space-y-6" onsubmit="event.preventDefault(); alert('Formulario enviado (simulación)');">
            <div>
              <label for="name" class="block text-sm font-medium text-slate-700 mb-1">Nombre completo</label>
              <input type="text" id="name" required class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" placeholder="Tu nombre" />
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="email" class="block text-sm font-medium text-slate-700 mb-1">Correo electrónico</label>
                <input type="email" id="email" required class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" placeholder="tu@email.com" />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-slate-700 mb-1">Teléfono</label>
                <input type="tel" id="phone" required class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" placeholder="+57 300 000 0000" />
              </div>
            </div>
            
            <div>
              <label for="message" class="block text-sm font-medium text-slate-700 mb-1">¿En qué podemos ayudarte?</label>
              <textarea id="message" rows="4" required class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all resize-none" placeholder="Cuéntanos brevemente el motivo de consulta..."></textarea>
            </div>
            
            <button type="submit" class="w-full bg-secondary hover:bg-secondary/90 text-white font-bold py-4 rounded-lg transition-colors flex items-center justify-center gap-2">
              <span>Enviar mensaje</span>
              <Icon name="lucide:send" class="w-5 h-5" />
            </button>
          </form>
          
          <div class="mt-6 text-center">
            <p class="text-sm text-slate-500 mb-4">O si prefieres atención inmediata:</p>
            <a href="https://wa.me/573001234567" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 w-full bg-[#25D366] hover:bg-[#20bd5a] text-white font-bold py-4 rounded-lg transition-colors shadow-md">
              <Icon name="lucide:message-circle" class="w-5 h-5" />
              Escríbenos por WhatsApp
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
