---
import { Icon } from 'astro-icon/components';
---

<footer class="bg-[#2D3748] text-white pt-20 pb-10 border-t border-[#7C9A6B]/20">
  <div class="container-empiria">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      
      <!-- Columna 1: Marca -->
      <div>
        <a href="#inicio" class="text-3xl font-serif font-bold text-white mb-6 inline-block">
          Empiria
        </a>
        <p class="text-[#A0AEC0] leading-relaxed mb-6">
          Centro especializado en evaluación y terapia de fonoaudiología y aprendizaje. Transformamos barreras en éxito.
        </p>
        <div class="flex gap-4">
          <a href="#" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-[#C17A5F] transition-colors" aria-label="Instagram">
            <Icon name="lucide:instagram" class="w-5 h-5" />
          </a>
          <a href="#" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-[#C17A5F] transition-colors" aria-label="Facebook">
            <Icon name="lucide:facebook" class="w-5 h-5" />
          </a>
        </div>
      </div>

      <!-- Columna 2: Enlaces Rápidos -->
      <div>
        <h3 class="text-lg font-bold mb-6 text-white/90">Enlaces Rápidos</h3>
        <ul class="space-y-4">
          <li><a href="#inicio" class="text-[#A0AEC0] hover:text-[#7C9A6B] transition-colors">Inicio</a></li>
          <li><a href="#quienes-somos" class="text-[#A0AEC0] hover:text-[#7C9A6B] transition-colors">Quiénes Somos</a></li>
          <li><a href="#servicios" class="text-[#A0AEC0] hover:text-[#7C9A6B] transition-colors">Servicios</a></li>
          <li><a href="#metodologia" class="text-[#A0AEC0] hover:text-[#7C9A6B] transition-colors">Metodología</a></li>
        </ul>
      </div>

      <!-- Columna 3: Servicios -->
      <div>
        <h3 class="text-lg font-bold mb-6 text-white/90">Intervenciones</h3>
        <ul class="space-y-4">
          <li class="text-[#A0AEC0]">Terapia de Lenguaje</li>
          <li class="text-[#A0AEC0]">Lectoescritura</li>
          <li class="text-[#A0AEC0]">Dislexia y Disgrafía</li>
          <li class="text-[#A0AEC0]">Estimulación Temprana</li>
        </ul>
      </div>

      <!-- Columna 4: Contacto -->
      <div>
        <h3 class="text-lg font-bold mb-6 text-white/90">Contacto</h3>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <Icon name="lucide:map-pin" class="w-5 h-5 text-[#7C9A6B] mt-1 shrink-0" />
            <span class="text-[#A0AEC0]">Bogotá, Colombia<br>Atención presencial y online</span>
          </li>
          <li class="flex items-center gap-3">
            <Icon name="lucide:phone" class="w-5 h-5 text-[#7C9A6B] shrink-0" />
            <a href="https://wa.me/573000000000" class="text-[#A0AEC0] hover:text-white transition-colors">+57 300 000 0000</a>
          </li>
          <li class="flex items-center gap-3">
            <Icon name="lucide:mail" class="w-5 h-5 text-[#7C9A6B] shrink-0" />
            <a href="mailto:contacto@empiria.com" class="text-[#A0AEC0] hover:text-white transition-colors">contacto@empiria.com</a>
          </li>
        </ul>
      </div>

    </div>

    <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-[#A0AEC0] text-sm">
        &copy; {new Date().getFullYear()} Empiria. Todos los derechos reservados.
      </p>
      <div class="flex gap-4 text-sm text-[#A0AEC0]">
        <a href="#" class="hover:text-white transition-colors">Términos de servicio</a>
        <a href="#" class="hover:text-white transition-colors">Política de privacidad</a>
      </div>
    </div>
  </div>
</footer>
