---
import { Icon } from 'astro-icon/components';

const segmentos = [
  {
    icon: 'lucide:baby',
    edad: '0–3 años',
    titulo: 'Bebés y primera infancia',
    descripcion: 'Estimulación temprana, prevención, aparición de las primeras palabras y bases del lenguaje.',
    color: '#7C9A6B'
  },
  {
    icon: 'lucide:school',
    edad: '4–10 años',
    titulo: 'Niños escolares',
    description: 'Pronunciación, estructuración del habla, lectura, escritura y adaptación al aprendizaje escolar.',
    color: '#C17A5F'
  },
  {
    icon: 'lucide:user',
    edad: '11+ años',
    titulo: 'Adolescentes y jóvenes',
    description: 'Comunicación avanzada, lectoescritura, comprensión y acompañamiento académico universitario.',
    color: '#3D6B7F'
  }
];
---

<section id="a-quienes-atendemos" class="section-padding bg-white">
  <div class="container-empiria">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="text-[#3D6B7F] text-sm font-semibold uppercase tracking-wider">A Quiénes Atendemos</span>
      <h2 class="text-3xl md:text-4xl font-serif font-bold text-[#2D3748] mt-3">
        Acompañamiento en cada etapa
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {segmentos.map(seg => (
        <div class="group relative bg-white border border-gray-100 rounded-3xl p-8 hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 overflow-hidden flex flex-col items-center text-center">
          <div class="absolute top-0 left-0 w-full h-1" style={`background-color: ${seg.color}`}></div>
          
          <div class="w-20 h-20 rounded-full flex items-center justify-center mb-6 transition-transform duration-300 group-hover:scale-110" style={`background-color: ${seg.color}15; color: ${seg.color}`}>
            <Icon name={seg.icon} class="w-10 h-10" />
          </div>
          
          <span class="inline-block px-4 py-1 rounded-full text-sm font-bold mb-4" style={`background-color: ${seg.color}15; color: ${seg.color}`}>
            {seg.edad}
          </span>
          
          <h3 class="text-2xl font-bold text-[#2D3748] mb-4">{seg.titulo}</h3>
          
          <p class="text-[#718096] leading-relaxed">
            {seg.descripcion || seg.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
