---
---

<section id="inicio" class="relative min-h-screen flex items-center pt-20 overflow-hidden reveal">
  <!-- Forma decorativa orgánica -->
  <div class="absolute top-0 right-0 w-1/2 h-full bg-[#7C9A6B]/10 rounded-l-[80px] md:rounded-l-[120px] -z-10"></div>
  <div class="absolute bottom-0 left-0 w-64 h-64 bg-[#C17A5F]/10 rounded-full blur-3xl -z-10"></div>

  <div class="container-empiria relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Contenido -->
      <div class="max-w-xl">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-[#7C9A6B]/15 text-[#5E7A4F] rounded-full text-sm font-medium mb-6">
          <span class="w-2 h-2 bg-[#7C9A6B] rounded-full animate-pulse"></span>
          🗣️ Fonoaudiología y Aprendizaje
        </span>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-bold text-[#2D3748] leading-tight mb-6 text-balance">
          Transformamos las barreras de <span class="text-[#C17A5F]">comunicación</span><br>
          en seguridad y éxito escolar.
        </h1>

        <p class="text-lg md:text-xl text-[#718096] mb-8 leading-relaxed">
          Fonoaudiología especializada en evaluación y terapia de lenguaje, lectoescritura y aprendizaje para niños, adolescentes y jóvenes. Más de 15 años de experiencia con enfoque científico y humano.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mb-10">
          <a href="https://wa.me/573000000000?text=Hola,%20quiero%20agendar%20una%20valoración%20gratuita" class="btn-primary">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Agendar valoración gratuita
          </a>
          <a href="#servicios" class="btn-secondary">
            Conoce nuestros servicios
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </a>
        </div>

        <!-- Prueba social -->
        <div class="flex items-center gap-4">
          <div class="flex -space-x-3">
            <div class="w-10 h-10 rounded-full bg-[#7C9A6B] border-2 border-white flex items-center justify-center text-white text-xs font-bold">A</div>
            <div class="w-10 h-10 rounded-full bg-[#C17A5F] border-2 border-white flex items-center justify-center text-white text-xs font-bold">M</div>
            <div class="w-10 h-10 rounded-full bg-[#3D6B7F] border-2 border-white flex items-center justify-center text-white text-xs font-bold">S</div>
          </div>
          <div>
            <div class="flex items-center gap-1">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
              <span class="text-sm font-semibold text-[#2D3748] ml-1">4.9</span>
            </div>
            <p class="text-sm text-[#718096]">200+ familias atendidas</p>
          </div>
        </div>
      </div>

      <!-- Imagen -->
      <div class="hidden lg:block relative">
        <div class="absolute inset-0 bg-[#7C9A6B]/20 rounded-[60px] rotate-3 transform"></div>
        <div class="relative bg-[#F5F0E8] rounded-[60px] overflow-hidden shadow-2xl aspect-[4/5] flex items-center justify-center">
          <div class="text-center p-8">
            <div class="w-32 h-32 bg-[#7C9A6B]/20 rounded-full mx-auto mb-4 flex items-center justify-center">
              <svg class="w-16 h-16 text-[#7C9A6B]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
            </div>
            <p class="text-[#718096] text-sm">[Foto de sesión terapéutica]</p>
            <p class="text-[#718096] text-xs mt-2">Reemplazar con imagen real</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
