---
import { Icon } from 'astro-icon/components';

const dificultades = [
  { icon: "lucide:book-open", title: "Dislexia y Lectura", desc: "Mejoramos la fluidez, comprensión y el disfrute por la lectura." },
  { icon: "lucide:pen-tool", title: "Disgrafía y Escritura", desc: "Desarrollamos la motricidad fina y la expresión escrita clara." },
  { icon: "lucide:calculator", title: "Discalculia", desc: "Facilitamos el razonamiento lógico y la resolución matemática." },
  { icon: "lucide:brain", title: "Atención y TDAH", desc: "Entrenamos la concentración y la autorregulación cognitiva." },
  { icon: "lucide:heart", title: "Conducta y Emociones", desc: "Manejamos la frustración, la impulsividad y la gestión emocional." },
  { icon: "lucide:users", title: "Ansiedad Escolar", desc: "Reducimos los miedos sociales y la presión por el rendimiento." },
];

const habilidades = [
  { icon: "lucide:message-circle", title: "Comunicación", desc: "Potenciamos la expresión verbal y la comprensión del entorno." },
  { icon: "lucide:lightbulb", title: "Pensamiento Crítico", desc: "Estimulamos la curiosidad y la capacidad de análisis." },
  { icon: "lucide:smile", title: "Habilidades Sociales", desc: "Fomentamos la empatía y la resolución asertiva de conflictos." },
  { icon: "lucide:calendar", title: "Planificación", desc: "Desarrollamos rutinas, funciones ejecutivas y métodos de estudio." },
  { icon: "lucide:star", title: "Autoestima", desc: "Construimos confianza para enfrentar nuevos retos con seguridad." },
  { icon: "lucide:graduation-cap", title: "Transiciones", desc: "Acompañamos el paso a nuevas etapas escolares sin estrés." },
];
---

<section id="servicios" class="py-20 md:py-32 bg-surface">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="text-center max-w-3xl mx-auto mb-16 fade-up">
      <h2 class="text-3xl md:text-5xl font-bold mb-6">Nuestros Servicios</h2>
      <p class="text-lg text-slate-600">
        Abordamos el desarrollo integral de los niños y adolescentes desde dos frentes: interviniendo en las áreas de dificultad y potenciando sus fortalezas naturales.
      </p>
    </div>

    <!-- Bloque A: Dificultades que atendemos -->
    <div class="mb-20">
      <div class="text-center mb-10 fade-up">
        <h3 class="text-2xl md:text-3xl font-bold text-secondary inline-block relative">
          Dificultades que atendemos
          <div class="absolute -bottom-2 left-1/4 right-1/4 h-1 bg-primary rounded-full opacity-50"></div>
        </h3>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {dificultades.map((item, index) => (
          <div class="bg-white p-8 rounded-2xl shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-slate-100 group fade-up" style={`transition-delay: ${index * 100}ms;`}>
            <div class="w-14 h-14 bg-primary/10 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-primary transition-colors duration-300">
              <Icon name={item.icon} class="w-7 h-7 text-primary group-hover:text-white transition-colors duration-300" />
            </div>
            <h4 class="text-xl font-bold text-secondary mb-3">{item.title}</h4>
            <p class="text-slate-600 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Bloque B: Habilidades que potenciamos -->
    <div>
      <div class="text-center mb-10 fade-up">
        <h3 class="text-2xl md:text-3xl font-bold text-secondary inline-block relative">
          Habilidades que potenciamos
          <div class="absolute -bottom-2 left-1/4 right-1/4 h-1 bg-accent rounded-full opacity-50"></div>
        </h3>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {habilidades.map((item, index) => (
          <div class="bg-white p-8 rounded-2xl shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-slate-100 group fade-up" style={`transition-delay: ${index * 100}ms;`}>
            <div class="w-14 h-14 bg-accent/10 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-accent transition-colors duration-300">
              <Icon name={item.icon} class="w-7 h-7 text-accent group-hover:text-white transition-colors duration-300" />
            </div>
            <h4 class="text-xl font-bold text-secondary mb-3">{item.title}</h4>
            <p class="text-slate-600 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
